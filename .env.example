# Supabase (étape 3 du guide-demarrage-technique.md)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL finale du site, utilisée pour le sitemap et les metadata OpenGraph
NEXT_PUBLIC_SITE_URL=https://example.com

# Assistant de prompt de code (outil 3) — laisser vide désactive l'outil proprement
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Vente du boilerplate — laisser vide affiche une liste d'attente à la place
NEXT_PUBLIC_CHECKOUT_URL=

# Liens d'affiliation (page /ressources) — laisser vide affiche un lien désactivé
NEXT_PUBLIC_HOSTINGER_AFFILIATE_URL=
NEXT_PUBLIC_INFOMANIAK_AFFILIATE_URL=

# Newsletter transactionnelle (non câblé dans le code, prévu pour plus tard)
RESEND_API_KEY=
